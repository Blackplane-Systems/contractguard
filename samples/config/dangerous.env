# Dangerous config file — ContractGuard sample

# Database connection
DATABASE_URL=postgresql://admin:password@db.example.com:5432/prod
DB_PASSWORD=admin123

# Security settings
SECRET_KEY=changeme
JWT_SECRET=test
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000
SSL_ENABLED=false
ALLOWED_HOSTS=*

# CORS — wide open
CORS_ALLOW_ALL_ORIGINS=True

# Placeholder credentials
INTERNAL_API_SECRET=demo-config-secret
PAYMENTS_TOKEN=demo-payments-token

# Logging
SHOW_ERRORS=true
VERBOSE_LOGGING=true
